# =====================================================================
# Copy this file to ".env" in the backend/ folder and fill in your keys.
# .env is already git-ignored - never commit real keys.
# =====================================================================

# ---------------- Groq LLM ----------------
# Create a free API token at https://console.groq.com/keys
GROQ_API_KEY=                       # <-- PASTE YOUR GROQ API KEY HERE

# Primary model (mandated by spec) - used for intent routing + structured
# entity extraction inside the LangGraph agent (see backend/app/agent/llm.py)
GROQ_PRIMARY_MODEL=gemma2-9b-it

# Secondary "context" model - used where a larger context window helps,
# e.g. summarizing a HCP's full interaction history (see agent/tools.py ->
# get_interaction_history, and agent/graph.py -> respond node)
GROQ_CONTEXT_MODEL=llama-3.3-70b-versatile

# ---------------- Database ----------------
# Pick ONE of the two connection strings below and comment out the other.

# Postgres
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/hcp_crm

# MySQL (alternative - comment the Postgres line above and uncomment this)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hcp_crm

# ---------------- App ----------------
FRONTEND_ORIGIN=http://localhost:3000
